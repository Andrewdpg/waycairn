{
  "name": "waycairn",
  "version": "0.1.4",
  "description": "Local-first MCP server for documenting a codebase as you work in it — architecture diagrams and notes stored in the repo, versioned in git, no cloud backend.",
  "bin": {
    "waycairn": "dist/bin/waycairn.js"
  },
  "files": [
    "dist/src",
    "dist/bin",
    "ui/dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andrewdpg/waycairn.git"
  },
  "homepage": "https://github.com/Andrewdpg/waycairn#readme",
  "bugs": {
    "url": "https://github.com/Andrewdpg/waycairn/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:ui": "npm run build --workspace=ui",
    "typecheck": "tsc --noEmit",
    "test": "npm run typecheck && vitest run",
    "prepublishOnly": "npm test && npm run build && npm run build:ui"
  },
  "keywords": ["mcp", "architecture", "documentation", "diagrams"],
  "author": "",
  "license": "ISC",
  "workspaces": ["ui"],
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "smol-toml": "^1.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
